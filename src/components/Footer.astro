---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-32">
  <div class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16">
    <div class="grid md:grid-cols-[1fr_auto] gap-10 mb-12">
      <div class="max-w-md">
        <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">
          Got a hard product problem? I'm taking on a small number of design
          and AI-native build engagements through 2026.
        </p>
        <a
          href="mailto:gabriel@oliveibriel.com"
          class="mt-4 inline-flex items-center gap-2 text-base font-medium link-underline"
        >
          gabriel@oliveibriel.com
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17 17 7M7 7h10v10"/>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-2 gap-8 text-sm">
        <div class="flex flex-col gap-2">
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Site</span>
          <a href="/work" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Work</a>
          <a href="/about" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">About</a>
          <a href="/writing" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Writing</a>
          <a href="/contact" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Contact</a>
        </div>
        <div class="flex flex-col gap-2">
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Connect</span>
          <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">LinkedIn ↗</a>
          <a href="https://wa.me/5541984541993" target="_blank" rel="noopener noreferrer" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">WhatsApp ↗</a>
          <a href="https://instagram.com/o.gabebastos" target="_blank" rel="noopener noreferrer" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Instagram ↗</a>
          <a href="mailto:gabriel@oliveibriel.com" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Email</a>
        </div>
      </div>
    </div>

    <div class="pt-8 border-t border-[var(--color-border-soft)] flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 font-mono text-[11px] text-[var(--color-fg-subtle)] uppercase tracking-wider">
      <div class="flex items-center gap-3">
        <span>© {year} Gabriel Oliveira</span>
        <span>·</span>
        <span>Curitiba, BR</span>
      </div>
      <button
        type="button"
        onclick="document.getElementById('cmdk-trigger')?.click()"
        class="hover:text-[var(--color-fg)] transition-colors text-left"
      >Press ⌘K to search</button>
    </div>
  </div>
</footer>
