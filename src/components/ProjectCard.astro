---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  size?: "wide" | "tall" | "normal" | "feature";
  index?: number;
}

const { project, size = project.size ?? "normal", index = 0 } = Astro.props;

const aspect =
  size === "wide" ? "aspect-[16/9]" :
  size === "tall" ? "aspect-[4/5]" :
  size === "feature" ? "aspect-[3/2]" :
  "aspect-[16/11]";
---

<a
  href={`/work/${project.slug}`}
  data-reveal
  data-reveal-delay={Math.min(index, 5)}
  class="project-card group block rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] overflow-hidden h-full"
>
  <div class={`${aspect} overflow-hidden relative`}>
    {project.image ? (
      <img
        src={project.image}
        alt={`${project.title} cover`}
        loading="lazy"
        decoding="async"
        class="project-card__img w-full h-full object-cover"
      />
    ) : (
      <div
        class="w-full h-full relative"
        style={`background:${project.gradient ?? "linear-gradient(135deg,#1f2937,#111827)"}`}
      >
        <div class="absolute inset-0 grid place-items-center">
          <span class="font-extrabold text-white/90 text-[clamp(2rem,5vw,4rem)] tracking-[-0.05em] mix-blend-overlay">
            {project.title}
          </span>
        </div>
      </div>
    )}
    <div class="project-card__shade absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0"></div>
  </div>
  <div class={`flex flex-col gap-1.5 ${size === "feature" ? "p-6 md:p-8" : "p-4 md:p-5"}`}>
    <div class="flex items-center justify-between gap-2 font-mono text-[10px] tracking-wider uppercase text-[var(--color-fg-subtle)]">
      <span class="flex items-center gap-1.5 min-w-0">
        <span class="truncate">{project.number} · {project.client}</span>
        {project.ai && (
          <span class="inline-flex shrink-0 items-center px-1.5 py-0.5 rounded text-[9px] font-mono uppercase tracking-wider bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/20">
            AI
          </span>
        )}
      </span>
      <span class="shrink-0">{project.year}</span>
    </div>
    <h3
      class={`font-bold tracking-tight ${size === "feature" ? "text-2xl md:text-3xl" : "text-lg md:text-xl"}`}
      style="letter-spacing:-0.025em;"
    >
      {project.title}
    </h3>
    <p class={`text-[var(--color-fg-muted)] leading-relaxed ${size === "feature" ? "text-sm md:text-base line-clamp-3" : "text-[13px] line-clamp-2"}`}>
      {project.summary}
    </p>
    <div class="font-mono text-[10px] text-[var(--color-fg-subtle)] mt-0.5 flex items-center gap-2">
      <span class="truncate">
        {project.metric ? `${project.metric.value} ${project.metric.label.toLowerCase()}` : project.type}
      </span>
      <span class="ml-auto inline-flex shrink-0 items-center gap-1 text-[var(--color-fg-subtle)] group-hover:text-[var(--color-accent)] group-hover:translate-x-0.5 transition-all">
        Read <span aria-hidden="true">→</span>
      </span>
    </div>
  </div>
</a>
