---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);

const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/about", label: "About" },
  { href: "/writing", label: "Writing", hideOn: "sm" as const },
];
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-border)] backdrop-blur-xl bg-[color-mix(in_srgb,var(--color-bg)_82%,transparent)]"
>
  <nav
    class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 h-14 flex items-center justify-between"
  >
    <a href="/" class="brand group inline-flex items-center gap-2.5">
      <span class="relative flex size-2 shrink-0">
        <span class="absolute inset-0 rounded-full bg-[var(--color-success)] animate-ping opacity-60"></span>
        <span class="relative size-2 rounded-full bg-[var(--color-success)]"></span>
      </span>
      <span class="text-[15px] tracking-tight leading-none flex items-baseline gap-[5px]">
        <span class="font-semibold text-[var(--color-fg)]">Gabriel</span>
        <span class="font-light text-[var(--color-fg-muted)] group-hover:text-[var(--color-fg)] transition-colors">Oliveira</span>
      </span>
      <span class="hidden lg:inline-flex font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--color-fg-subtle)] ml-1 pl-3 border-l border-[var(--color-border)] py-0.5">
        Designer · Curitiba
      </span>
    </a>

    <div class="flex items-center gap-1 text-sm">
      <div id="nav-links" class="relative flex items-center">
        <span id="nav-pill" class="absolute top-1/2 -translate-y-1/2 rounded-md bg-[var(--color-bg-soft)] border border-[var(--color-border)] pointer-events-none transition-[transform,width,opacity] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] opacity-0" aria-hidden="true"></span>
        {navLinks.map((link) => (
          <a
            href={link.href}
            data-active={isActive(link.href) ? "true" : "false"}
            class={`nav-link relative z-10 magnetic px-3 py-1.5 rounded-md transition-colors ${link.hideOn === "sm" ? "hidden sm:inline-block" : ""} ${isActive(link.href) ? "text-[var(--color-fg)]" : "text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"}`}
            data-magnetic-strength="6"
          >
            {link.label}
          </a>
        ))}
      </div>

      <button
        id="cmdk-trigger"
        type="button"
        aria-label="Open command palette"
        class="ml-2 hidden sm:inline-flex items-center gap-2 px-2.5 py-1.5 rounded-md border border-[var(--color-border)] text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:border-[var(--color-border-strong)] transition-colors text-xs font-mono"
      >
        <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        ⌘K
      </button>

      <a
        href="mailto:gabriel@oliveibriel.com"
        class="ml-2 px-3 py-1.5 rounded-md bg-[var(--color-fg)] hover:bg-[var(--color-accent)] text-white text-sm font-medium transition-colors"
      >
        Get in touch
      </a>
    </div>
  </nav>
</header>

<script>
  function setupNav() {
    const cmdkTrigger = document.getElementById("cmdk-trigger");
    if (cmdkTrigger && !cmdkTrigger.dataset.bound) {
      cmdkTrigger.dataset.bound = "true";
      cmdkTrigger.addEventListener("click", () => {
        const overlay = document.getElementById("cmdk");
        if (overlay) {
          overlay.classList.add("open");
          const input = document.getElementById("cmdk-input") as HTMLInputElement | null;
          setTimeout(() => input?.focus(), 50);
        }
      });
    }

    // Active pill — slides under hovered/active link
    const container = document.getElementById("nav-links");
    const pill = document.getElementById("nav-pill");
    if (!container || !pill) return;
    const links = Array.from(container.querySelectorAll<HTMLAnchorElement>(".nav-link"));

    const positionPill = (target: HTMLElement | null) => {
      if (!target) {
        pill.style.opacity = "0";
        return;
      }
      // Use offset* (DOM layout) instead of getBoundingClientRect so the
      // magnetic transform on the link doesn't make the pill jitter.
      const x = target.offsetLeft;
      const w = target.offsetWidth;
      const h = target.offsetHeight;
      pill.style.transform = `translate(${x}px, -50%)`;
      pill.style.width = `${w}px`;
      pill.style.height = `${h}px`;
      pill.style.opacity = "1";
    };

    const activeLink = links.find((l) => l.dataset.active === "true") ?? null;
    // Defer one frame so layout has settled
    requestAnimationFrame(() => positionPill(activeLink));

    links.forEach((link) => {
      link.addEventListener("mouseenter", () => positionPill(link));
      link.addEventListener("focus", () => positionPill(link));
    });
    container.addEventListener("mouseleave", () => positionPill(activeLink));
    window.addEventListener("resize", () => positionPill(activeLink));
  }
  setupNav();
  document.addEventListener("astro:after-swap", setupNav);
  document.addEventListener("astro:page-load", setupNav);
</script>
