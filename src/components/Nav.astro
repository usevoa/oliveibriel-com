---
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-border)] backdrop-blur-md bg-[color-mix(in_srgb,var(--color-bg)_80%,transparent)]"
>
  <nav
    class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 h-14 flex items-center justify-between"
  >
    <a
      href="/"
      class="text-sm font-semibold tracking-tight hover:text-[var(--color-accent-soft)] transition-colors"
    >
      Gabriel Oliveira
    </a>

    <div class="flex items-center gap-1 text-sm">
      <a
        href="/work"
        class={`px-3 py-1.5 rounded-md transition-colors ${isActive("/work") ? "text-[var(--color-fg)]" : "text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"}`}
      >
        Work
      </a>
      <a
        href="/about"
        class={`px-3 py-1.5 rounded-md transition-colors ${isActive("/about") ? "text-[var(--color-fg)]" : "text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"}`}
      >
        About
      </a>
      <a
        href="/writing"
        class={`px-3 py-1.5 rounded-md transition-colors ${isActive("/writing") ? "text-[var(--color-fg)]" : "text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"}`}
      >
        Writing
      </a>

      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        class="ml-2 size-8 grid place-items-center rounded-md text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-bg-elevated)] transition-colors"
      >
        <svg class="theme-icon-dark size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="theme-icon-light size-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
      </button>

      <a
        href="/contact"
        class="ml-2 px-3 py-1.5 rounded-md bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-sm font-medium transition-colors"
      >
        Get in touch
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  // Dark by default. Only go light if user explicitly chose it.
  (() => {
    const stored = localStorage.getItem("theme");
    if (stored === "light") document.documentElement.classList.add("light");
  })();
</script>

<script>
  function setupThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = "true";

    const updateIcons = () => {
      const isLight = document.documentElement.classList.contains("light");
      document.querySelectorAll(".theme-icon-dark").forEach((el) => {
        el.classList.toggle("hidden", isLight);
      });
      document.querySelectorAll(".theme-icon-light").forEach((el) => {
        el.classList.toggle("hidden", !isLight);
      });
    };

    updateIcons();

    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const toLight = !root.classList.contains("light");
      const apply = () => {
        root.classList.toggle("light", toLight);
        localStorage.setItem("theme", toLight ? "light" : "dark");
        updateIcons();
      };
      // @ts-expect-error - View Transitions API
      if (document.startViewTransition) {
        // @ts-expect-error
        document.startViewTransition(apply);
      } else {
        apply();
      }
    });
  }

  setupThemeToggle();
  document.addEventListener("astro:after-swap", setupThemeToggle);
</script>
