---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SEO from "../components/SEO.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CommandPalette from "../components/CommandPalette.astro";
import ScrollProgress from "../components/ScrollProgress.astro";
import RevealOnScroll from "../components/RevealOnScroll.astro";
import CursorSpotlight from "../components/CursorSpotlight.astro";
import Magnetic from "../components/Magnetic.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,200;1,300;1,400&family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <SEO {...props} />
    <ClientRouter />
    <script is:inline>
      // Disable browser's automatic scroll restoration so refresh and
      // forward/back nav always land at the top of the page instead of
      // wherever the previous session had scrolled to.
      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }
      // Astro's ClientRouter dispatches astro:page-load on navigation —
      // reset scroll there too so SPA-style nav matches refresh behavior.
      document.addEventListener("astro:page-load", () => {
        // Skip if URL has a hash anchor (TOC chips, deep links) so users
        // who clicked a #section actually jump to that section.
        if (!location.hash) window.scrollTo(0, 0);
      });
    </script>
  </head>
  <body class="font-sans antialiased">
    <ScrollProgress />
    <Nav />
    <main class="min-h-[calc(100vh-3.5rem)]">
      <slot />
    </main>
    <Footer />
    <CommandPalette />
    <RevealOnScroll />
    <CursorSpotlight />
    <Magnetic />
  </body>
</html>
