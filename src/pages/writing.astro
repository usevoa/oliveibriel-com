---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Writing — Gabriel Oliveira"
  description="Notes and essays on product design, design systems, and AI-native workflows."
>
  <section class="max-w-[var(--container-prose)] mx-auto px-6 md:px-10 pt-20 pb-12">
    <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
      Writing
    </span>
    <h1
      class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight"
      style="letter-spacing: var(--tracking-tightest);"
    >
      Notes & essays.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-fg-muted)]">
      Short writing on product design, systems, and AI-native workflows.
    </p>
  </section>

  <section class="max-w-[var(--container-prose)] mx-auto px-6 md:px-10 py-8">
    <p class="font-mono text-sm text-[var(--color-fg-subtle)]">
      First posts coming soon.
    </p>
  </section>
</BaseLayout>
