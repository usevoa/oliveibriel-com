---
import Brutalist from "../components/teste2/Brutalist.tsx";
import VariantSEO from "../components/VariantSEO.astro";
import "../styles/tailwind-only.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <VariantSEO
      variant="teste2"
      title="Gabriel Oliveira — Senior Product Designer · Lab"
      description="Senior Product Designer · 10+ years across industrial SaaS, design systems, and AI-native tools. Lead UX on IRIS V3 at NETZSCH; co-founder of VOA Digital."
    />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root { color-scheme: light; }
      html, body { background: #F4F4EE; color: #0a0a0a; }
      html { font-family: "Inter", ui-sans-serif, system-ui, sans-serif; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      body { font-feature-settings: "ss01"; min-height: 100vh; }
      ::selection { background: #84CC16; color: #0a0a0a; }
      .font-mono, [class*="font-mono"] { font-family: "JetBrains Mono", ui-monospace, monospace; }
      :focus-visible { outline: 2px solid #65A30D; outline-offset: 3px; }
      @keyframes blink { 0%, 100% { opacity: 1 } 50% { opacity: 0 } }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
  </head>
  <body>
    <Brutalist client:load />
  </body>
</html>
