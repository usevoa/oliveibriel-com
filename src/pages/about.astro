---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About — Gabriel Oliveira"
  description="Senior Product Designer based in Curitiba, Brazil. Co-founder of VOA Digital."
>
  <section class="max-w-[var(--container-prose)] mx-auto px-6 md:px-10 pt-20 pb-12">
    <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
      About
    </span>
    <h1
      class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight"
      style="letter-spacing: var(--tracking-tightest);"
    >
      Designing clarity for complex systems.
    </h1>
  </section>

  <section class="max-w-[var(--container-prose)] mx-auto px-6 md:px-10 py-8 prose-content">
    <p class="text-lg text-[var(--color-fg-muted)] leading-relaxed">
      I'm a Senior Product Designer based in Curitiba, Brazil. I work on IRIS V3
      at NETZSCH — a global industrial SaaS platform — and co-run VOA Digital
      with my sister, where we build products and websites for clinical and
      service businesses.
    </p>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed">
      My focus is B2B, enterprise, and design systems. I care about clarity,
      systems thinking, and shipping. Lately I've been exploring AI-native
      workflows — building products that pair design intent with LLM-powered
      execution.
    </p>
  </section>
</BaseLayout>
