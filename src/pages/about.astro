---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About — Gabriel Oliveira"
  description="Senior Product Designer based in Curitiba, Brazil. Co-founder of VOA Digital."
>
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-12">
    <div class="grid md:grid-cols-[1fr_320px] gap-12 items-start">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
          About
        </span>
        <h1
          class="mt-3 text-4xl md:text-6xl font-extrabold leading-[1.02]"
          style="letter-spacing: -0.045em;"
        >
          Designing clarity for complex systems.
        </h1>
        <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
          I'm a Senior Product Designer based in Curitiba, Brazil. I work on
          <span class="text-[var(--color-fg)]">IRIS V3</span> at NETZSCH — a
          global industrial SaaS platform — and co-run
          <span class="text-[var(--color-fg)]">VOA Digital</span> with my sister,
          where we build products and websites for clinical and service businesses.
        </p>
      </div>
      <aside class="md:sticky md:top-20">
        <div class="aspect-[4/5] rounded-xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
          <img
            src="https://storage.googleapis.com/2026portfolio/Home/Link.jpg"
            alt="Gabriel Oliveira"
            class="w-full h-full object-cover"
          />
        </div>
        <dl class="mt-5 grid gap-4 font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
          <div class="flex flex-col gap-1">
            <dt>Role</dt>
            <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">Senior Product Designer</dd>
          </div>
          <div class="flex flex-col gap-1">
            <dt>Focus</dt>
            <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">B2B SaaS · Design Systems · AI</dd>
          </div>
          <div class="flex flex-col gap-1">
            <dt>Based in</dt>
            <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">Curitiba, Brazil</dd>
          </div>
          <div class="flex flex-col gap-1">
            <dt>Currently</dt>
            <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">NETZSCH · VOA Digital</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <!-- Journey -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Journey</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          A decade of work.
        </h2>
      </div>
      <div class="prose-content max-w-2xl flex flex-col gap-5 text-[var(--color-fg-muted)] leading-relaxed">
        <p>
          I started with games — third-person shooters and experimental 3D — before moving into mobile,
          fintech, and enterprise. I've designed for millions of users at SuperDigital and shipped
          quiet, technical interfaces for the engineers running NETZSCH analytical instruments.
        </p>
        <p>
          My focus today is B2B, enterprise, and design systems. I care about clarity, systems
          thinking, and shipping. Lately I've been exploring AI-native workflows — building
          products that pair design intent with LLM-powered execution, including a multi-tenant
          clinical SaaS and a CLI that pushes generated training plans into Garmin Connect.
        </p>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Skills</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          What I do.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-6 max-w-3xl">
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Design</h3>
          <ul class="flex flex-wrap gap-2">
            {["Product Design", "UX Strategy", "Design Systems", "Information Architecture", "Prototyping", "Usability Testing", "Workshops", "Accessibility"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Tools & Code</h3>
          <ul class="flex flex-wrap gap-2">
            {["Figma", "Storybook", "React", "TypeScript", "Tailwind", "Astro", "Next.js", "Supabase", "Salesforce"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">AI workflow</h3>
          <ul class="flex flex-wrap gap-2">
            {["Claude Code", "Cursor", "LLM prompting", "Vibe coding", "AI-assisted scaffolding", "Schema-driven prompts"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Domains</h3>
          <ul class="flex flex-wrap gap-2">
            {["Industrial SaaS", "B2B platforms", "Fintech", "Healthcare", "Public sector", "Games"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Outside of work -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Outside of work</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          Off the clock.
        </h2>
      </div>
      <div class="max-w-2xl text-[var(--color-fg-muted)] leading-relaxed">
        <p>
          Cinema, games, and storytelling. Four French Bulldogs at home. Running long
          distances on weekends. Cooking when I have the patience and ordering when I don't.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20 border-t border-[var(--color-border)]">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          Let's build something together.
        </h2>
        <p class="mt-2 text-[var(--color-fg-muted)]">
          Currently open to new projects and full-time roles.
        </p>
      </div>
      <div class="flex gap-3">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-sm font-medium transition-colors"
        >
          Get in touch
        </a>
        <a
          href="/work"
          class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md border border-[var(--color-border)] hover:bg-[var(--color-bg-elevated)] text-sm font-medium transition-colors"
        >
          See work
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
