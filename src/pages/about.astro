---
import BaseLayout from "../layouts/BaseLayout.astro";

const careerTimeline = [
  {
    range: "2023 → Present",
    org: "NETZSCH",
    role: "Senior UX/UI Designer · sole designer on the platform",
    summary:
      "IRIS V3 — global HMI platform across 6 product lines and 3 languages. Plants design system, Customer Portal, IRIS DS.",
  },
  {
    range: "Active",
    org: "VOA Digital",
    role: "Co-founder · Product & Design",
    summary:
      "Agency I run with my sister. Internal tools, client websites, and the SaaS products we ship under our own roof.",
  },
  {
    range: "2024",
    org: "TechCo.lab",
    role: "Designer-builder · solo",
    summary:
      "Concept-to-deploy landing using Figma Make + AI workflow. Designer-owned full stack.",
  },
  {
    range: "2022",
    org: "Connecticut.gov",
    role: "Product Designer",
    summary:
      "MyCT — citizen-facing public-sector portal. WCAG 2.1 AA, plain language, mobile-first.",
  },
  {
    range: "2019",
    org: "Santander",
    role: "Product Designer",
    summary:
      "SuperDigital — fintech mobile banking serving millions across Latin America.",
  },
  {
    range: "2018",
    org: "Dell",
    role: "Product Designer",
    summary:
      "Dell Expert Network — certification platform for enterprise partners.",
  },
  {
    range: "2016 → 2017",
    org: "Indie",
    role: "Designer-developer",
    summary:
      "Two indie games — EYE (third-person narrative shooter) and Gan Dath (experimental 3D). Where I started.",
  },
];
---

<BaseLayout
  title="About — Gabriel Oliveira"
  description="Senior Product Designer with 10+ years across industrial SaaS, design systems, fintech, and public-sector platforms. Based in Curitiba, Brazil. Co-founder of VOA Digital."
>
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-12">
    <div class="grid md:grid-cols-[1fr_320px] gap-12 items-start">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
          About
        </span>
        <h1
          class="mt-3 text-4xl md:text-6xl font-extrabold leading-[1.02]"
          style="letter-spacing: -0.045em;"
        >
          Senior Product Designer.<br />
          <span class="text-[var(--color-fg-muted)]">10+ years shipping.</span>
        </h1>
        <p class="mt-6 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
          Based in Curitiba, Brazil. Currently leading UX on
          <span class="text-[var(--color-fg)]">IRIS V3</span> — NETZSCH's global
          industrial HMI platform — and co-founder of
          <span class="text-[var(--color-fg)]">VOA Digital</span>, a small studio
          building products and websites for clinical and service businesses.
        </p>
        <p class="mt-4 text-lg text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
          Decade across industrial SaaS, design systems, fintech, public-sector
          platforms, and indie games. B2B, complex domains, and AI-native
          workflows are where I'm most useful.
        </p>
      </div>
      <aside class="md:sticky md:top-20">
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
          <div class="flex items-center gap-2.5 mb-5 pb-5 border-b border-[var(--color-border)]">
            <span class="relative flex size-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-success)] opacity-60"></span>
              <span class="relative inline-flex rounded-full size-2 bg-[var(--color-success)]"></span>
            </span>
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-muted)]">
              Available · May 2026
            </span>
          </div>
          <dl class="grid gap-4 font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
            <div class="flex flex-col gap-1">
              <dt>Role</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">Senior Product Designer</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>Focus</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">B2B SaaS · Design Systems · AI</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>Based in</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">Curitiba, Brazil · UTC−3</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>Currently</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">NETZSCH · VOA Digital</dd>
            </div>
            <div class="flex flex-col gap-1">
              <dt>Languages</dt>
              <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">Portuguese (native) · English (fluent)</dd>
            </div>
          </dl>
        </div>
        <div class="mt-4 flex flex-col gap-2 font-mono text-[11px]">
          <a
            href="/gabriel-oliveira-cv.pdf"
            class="px-4 py-2.5 rounded-md bg-[var(--color-fg)] hover:bg-[var(--color-accent)] text-white flex items-center justify-between gap-2 transition-colors"
            download
          >
            <span class="uppercase tracking-wider text-[10px] opacity-80">Resume / CV</span>
            <span class="font-sans text-sm inline-flex items-center gap-1.5">
              Download PDF
              <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </span>
          </a>
          <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="px-4 py-2.5 rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg)] flex items-center justify-between gap-2 text-[var(--color-fg)] transition-colors">
            <span class="uppercase tracking-wider text-[10px] text-[var(--color-fg-subtle)]">LinkedIn</span>
            <span class="font-sans text-sm">/in/oliveibriel ↗</span>
          </a>
          <a href="https://github.com/oliveibriel" target="_blank" rel="noopener noreferrer" class="px-4 py-2.5 rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg)] flex items-center justify-between gap-2 text-[var(--color-fg)] transition-colors">
            <span class="uppercase tracking-wider text-[10px] text-[var(--color-fg-subtle)]">GitHub</span>
            <span class="font-sans text-sm">@oliveibriel ↗</span>
          </a>
          <a href="mailto:gabriel@oliveibriel.com" class="px-4 py-2.5 rounded-md border border-[var(--color-border)] hover:border-[var(--color-fg)] flex items-center justify-between gap-2 text-[var(--color-fg)] transition-colors">
            <span class="uppercase tracking-wider text-[10px] text-[var(--color-fg-subtle)]">Email</span>
            <span class="font-sans text-sm">gabriel@oliveibriel.com</span>
          </a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Journey -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Journey</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          A decade of work.
        </h2>
      </div>
      <div class="prose-content max-w-2xl flex flex-col gap-5 text-[var(--color-fg-muted)] leading-relaxed">
        <p>
          I started with games — third-person shooters and experimental 3D — before moving into mobile,
          fintech, and enterprise. I've designed for millions of users at SuperDigital and shipped
          quiet, technical interfaces for the engineers running NETZSCH analytical instruments.
        </p>
        <p>
          My focus today is B2B, enterprise, and design systems. I care about clarity, systems
          thinking, and shipping. Lately I've been exploring AI-native workflows — building
          products that pair design intent with LLM-powered execution, including a multi-tenant
          clinical SaaS and a CLI that pushes generated training plans into Garmin Connect.
        </p>
      </div>
    </div>
  </section>

  <!-- Career timeline — chronological for recruiter scan -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Experience</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          Career timeline.
        </h2>
        <p class="mt-3 text-sm text-[var(--color-fg-muted)] leading-relaxed">
          Selected engagements, ordered by year. Full work history on
          <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="link-underline text-[var(--color-fg)]">LinkedIn</a>.
        </p>
      </div>
      <ol class="flex flex-col">
        {careerTimeline.map((item, i) => (
          <li class={`grid grid-cols-[1fr] sm:grid-cols-[10rem_1fr] gap-2 sm:gap-8 py-5 ${i === 0 ? "" : "border-t border-[var(--color-border)]"}`}>
            <div class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)] tabular pt-0.5">
              {item.range}
            </div>
            <div>
              <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5">
                <span class="text-base md:text-lg font-semibold text-[var(--color-fg)]">{item.org}</span>
                <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">·</span>
                <span class="text-sm text-[var(--color-fg-muted)]">{item.role}</span>
              </div>
              <p class="mt-1.5 text-sm text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
                {item.summary}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Skills -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Skills</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          What I do.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-6 max-w-3xl">
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Design</h3>
          <ul class="flex flex-wrap gap-2">
            {["Product Design", "UX Strategy", "Design Systems", "Information Architecture", "Prototyping", "Usability Testing", "Workshops", "Accessibility"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Tools & Code</h3>
          <ul class="flex flex-wrap gap-2">
            {["Figma", "Storybook", "React", "TypeScript", "Tailwind", "Astro", "Next.js", "Supabase", "Salesforce"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">AI workflow</h3>
          <ul class="flex flex-wrap gap-2">
            {["Claude Code", "Cursor", "LLM prompting", "Vibe coding", "AI-assisted scaffolding", "Schema-driven prompts"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)] mb-3">Domains</h3>
          <ul class="flex flex-wrap gap-2">
            {["Industrial SaaS", "B2B platforms", "Fintech", "Healthcare", "Public sector", "Games"].map((skill) => (
              <li class="px-2.5 py-1 rounded-md border border-[var(--color-border)] text-xs text-[var(--color-fg-muted)]">{skill}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Outside of work -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Outside of work</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          Off the clock.
        </h2>
      </div>
      <div class="max-w-2xl text-[var(--color-fg-muted)] leading-relaxed flex flex-col gap-4">
        <p>
          Four French Bulldogs at home — Link, Zelda, Charlie, Nolan — they run my
          mornings and ruin my Figma demos.
        </p>
        <p>
          Long-distance running on weekends (which is how Garmin Coach
          accidentally became a side project). Cinema and indie games are my
          shortcut into other people's craft — a 90s Kurosawa film and a
          well-tuned Souls-like teach me as much about pacing and feedback as any
          design book.
        </p>
        <p>
          I cook when I have the patience and order when I don't. I read more
          interface code than design theory.
        </p>
      </div>
    </div>
  </section>

  <!-- Talks & writing teaser -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Elsewhere</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          Where to find me.
        </h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-3 max-w-2xl">
        <a href="https://www.linkedin.com/in/oliveibriel" target="_blank" rel="noopener noreferrer" class="border border-[var(--color-border)] rounded-lg p-5 hover:border-[var(--color-fg)] transition-colors">
          <div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">LinkedIn ↗</div>
          <div class="mt-2 font-medium text-[var(--color-fg)]">/in/oliveibriel</div>
          <div class="text-sm text-[var(--color-fg-muted)] mt-1">Career, recommendations, the long-form CV.</div>
        </a>
        <a href="https://github.com/oliveibriel" target="_blank" rel="noopener noreferrer" class="border border-[var(--color-border)] rounded-lg p-5 hover:border-[var(--color-fg)] transition-colors">
          <div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">GitHub ↗</div>
          <div class="mt-2 font-medium text-[var(--color-fg)]">@oliveibriel</div>
          <div class="text-sm text-[var(--color-fg-muted)] mt-1">Source for Garmin Coach, this site, side experiments.</div>
        </a>
        <a href="mailto:gabriel@oliveibriel.com" class="border border-[var(--color-border)] rounded-lg p-5 hover:border-[var(--color-fg)] transition-colors">
          <div class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Email</div>
          <div class="mt-2 font-medium text-[var(--color-fg)]">gabriel@oliveibriel.com</div>
          <div class="text-sm text-[var(--color-fg-muted)] mt-1">Direct line. I respond within a few days.</div>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
