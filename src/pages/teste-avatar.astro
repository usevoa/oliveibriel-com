---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Teste · Avatar mouse-follow"
  description="Avatar inspirado no hero, seguindo o mouse com cabeça e olhos."
>
  <main class="avatar-stage">
    <div class="avatar-frame" id="avatarFrame">
      <svg
        id="avatarSvg"
        viewBox="0 0 400 500"
        xmlns="http://www.w3.org/2000/svg"
        aria-label="Avatar segurando um laptop, olhos seguem o cursor"
      >
        <defs>
          <linearGradient id="shirtGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#9c4733" />
            <stop offset="1" stop-color="#7a3424" />
          </linearGradient>
          <linearGradient id="laptopGrad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#dde0e3" />
            <stop offset="1" stop-color="#b3b8bd" />
          </linearGradient>
          <radialGradient id="cheekGrad" cx="0.5" cy="0.5" r="0.5">
            <stop offset="0" stop-color="#e88072" stop-opacity="0.5" />
            <stop offset="1" stop-color="#e88072" stop-opacity="0" />
          </radialGradient>
          <filter id="softShadow" x="-30%" y="-30%" width="160%" height="160%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="2.5" />
            <feOffset dx="0" dy="4" />
            <feComponentTransfer><feFuncA type="linear" slope="0.18" /></feComponentTransfer>
            <feMerge><feMergeNode /><feMergeNode in="SourceGraphic" /></feMerge>
          </filter>
        </defs>

        <!-- ground shadow -->
        <ellipse cx="200" cy="488" rx="120" ry="10" fill="rgba(28,25,23,0.10)" />

        <!-- ============== TORSO (idle breathing) ============== -->
        <g id="torso" filter="url(#softShadow)">
          <!-- shirt body -->
          <path d="M 90 340 Q 100 260 138 240 L 262 240 Q 300 260 310 340 L 320 500 L 80 500 Z" fill="url(#shirtGrad)" />
          <!-- white tee V-neck peeking -->
          <path d="M 175 240 Q 200 268 225 240 L 225 268 Q 200 280 175 268 Z" fill="#fafaf9" />
          <!-- shirt placket center stripe -->
          <line x1="200" y1="268" x2="200" y2="500" stroke="rgba(0,0,0,0.18)" stroke-width="1.5" />
          <!-- shirt buttons -->
          <circle cx="200" cy="300" r="2.2" fill="#3a1a10" />
          <circle cx="200" cy="340" r="2.2" fill="#3a1a10" />
          <circle cx="200" cy="380" r="2.2" fill="#3a1a10" />
          <circle cx="200" cy="420" r="2.2" fill="#3a1a10" />
          <!-- subtle plaid texture lines -->
          <line x1="120" y1="300" x2="280" y2="300" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
          <line x1="115" y1="350" x2="285" y2="350" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
          <line x1="110" y1="400" x2="290" y2="400" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
          <line x1="160" y1="240" x2="160" y2="500" stroke="rgba(0,0,0,0.06)" stroke-width="1" />
          <line x1="240" y1="240" x2="240" y2="500" stroke="rgba(0,0,0,0.06)" stroke-width="1" />

          <!-- ============== LEFT ARM (his left = viewer's right) ============== -->
          <!-- upper arm -->
          <path d="M 295 250 Q 330 280 340 360 L 320 380 Q 305 320 285 290 Z" fill="url(#shirtGrad)" />
          <!-- forearm with skin showing -->
          <path d="M 320 380 Q 320 420 315 460 L 295 460 Q 285 420 295 380 Z" fill="#e8b89a" />
          <!-- tattoo lines on forearm -->
          <path d="M 305 400 Q 315 405 305 415 Q 295 420 305 425" fill="none" stroke="rgba(40,20,10,0.35)" stroke-width="1.5" stroke-linecap="round" />
          <circle cx="306" cy="430" r="2" fill="rgba(40,20,10,0.30)" />
          <!-- watch -->
          <rect x="296" y="445" width="20" height="9" rx="2" fill="#1a1a1a" />
          <rect x="299" y="447" width="14" height="5" rx="1" fill="#3a3a3a" />
          <!-- right hand holding nothing, fist-ish -->
          <ellipse cx="305" cy="468" rx="14" ry="11" fill="#e8b89a" />
          <line x1="298" y1="466" x2="298" y2="473" stroke="#c89878" stroke-width="1" />
          <line x1="305" y1="466" x2="305" y2="473" stroke="#c89878" stroke-width="1" />
          <line x1="312" y1="466" x2="312" y2="473" stroke="#c89878" stroke-width="1" />

          <!-- ============== RIGHT ARM (holding laptop) ============== -->
          <!-- upper arm bent forward -->
          <path d="M 105 250 Q 70 280 65 350 L 90 380 Q 100 320 115 290 Z" fill="url(#shirtGrad)" />
          <!-- forearm bent forward, holding laptop -->
          <path d="M 80 365 Q 90 400 130 410 L 145 388 Q 110 380 100 360 Z" fill="#e8b89a" />
          <!-- tattoo on this forearm -->
          <path d="M 105 388 Q 115 392 110 400 Q 105 405 115 408" fill="none" stroke="rgba(40,20,10,0.35)" stroke-width="1.5" stroke-linecap="round" />
          <circle cx="120" cy="395" r="1.5" fill="rgba(40,20,10,0.30)" />

          <!-- LAPTOP held in front -->
          <g transform="translate(0,0)">
            <!-- laptop bottom -->
            <path d="M 130 405 L 285 405 L 295 425 L 120 425 Z" fill="url(#laptopGrad)" />
            <path d="M 120 425 L 295 425 L 290 432 L 125 432 Z" fill="#909499" />
            <!-- laptop screen -->
            <path d="M 138 405 L 277 405 L 282 365 L 133 365 Z" fill="url(#laptopGrad)" />
            <rect x="143" y="370" width="134" height="30" rx="2" fill="#1a1a1a" />
            <!-- screen content (subtle) -->
            <line x1="150" y1="378" x2="200" y2="378" stroke="#8F7FBB" stroke-width="1.5" stroke-linecap="round" />
            <line x1="150" y1="385" x2="220" y2="385" stroke="rgba(255,255,255,0.4)" stroke-width="1" />
            <line x1="150" y1="391" x2="190" y2="391" stroke="rgba(255,255,255,0.25)" stroke-width="1" />
            <!-- apple-style notch (just dot) -->
            <circle cx="210" cy="368" r="1" fill="#444" />
          </g>

          <!-- right hand gripping laptop -->
          <ellipse cx="135" cy="412" rx="14" ry="10" fill="#e8b89a" />
        </g>

        <!-- ============== HEAD (mouse-follow) ============== -->
        <g id="head">
          <g filter="url(#softShadow)">
            <!-- neck -->
            <path d="M 178 230 L 178 255 Q 200 270 222 255 L 222 230 Z" fill="#d4a489" />
            <!-- neck shadow -->
            <ellipse cx="200" cy="240" rx="22" ry="6" fill="rgba(0,0,0,0.12)" />

            <!-- head shape (wider on top, soft jaw) -->
            <path d="M 138 165 Q 138 90 200 80 Q 262 90 262 165 Q 262 215 240 232 Q 220 246 200 246 Q 180 246 160 232 Q 138 215 138 165 Z" fill="#e8b89a" />

            <!-- subtle cheek blush -->
            <ellipse cx="160" cy="200" rx="14" ry="9" fill="url(#cheekGrad)" />
            <ellipse cx="240" cy="200" rx="14" ry="9" fill="url(#cheekGrad)" />

            <!-- HAIR — short brown, with side parted look -->
            <path d="M 138 165 Q 130 100 200 78 Q 270 95 262 168 L 262 130 Q 250 110 230 108 Q 210 122 195 118 Q 180 110 165 116 Q 148 124 145 145 Q 140 158 138 165 Z" fill="#2a1810" />
            <!-- hair highlight -->
            <path d="M 148 130 Q 175 108 220 110" fill="none" stroke="#3d2418" stroke-width="2" stroke-linecap="round" />

            <!-- EARS -->
            <ellipse cx="138" cy="178" rx="7" ry="12" fill="#d4a489" />
            <ellipse cx="138" cy="178" rx="3" ry="7" fill="#b88a6e" />
            <ellipse cx="262" cy="178" rx="7" ry="12" fill="#d4a489" />
            <ellipse cx="262" cy="178" rx="3" ry="7" fill="#b88a6e" />

            <!-- BEARD — full mid-length -->
            <path d="M 156 195 Q 152 210 158 226 Q 175 248 200 250 Q 225 248 242 226 Q 248 210 244 195 Q 235 218 225 222 Q 200 232 175 222 Q 165 218 156 195 Z" fill="#2a1810" />
            <!-- beard texture lines -->
            <path d="M 170 215 Q 175 222 172 230" fill="none" stroke="#1a0e08" stroke-width="0.7" />
            <path d="M 200 220 Q 200 230 200 240" fill="none" stroke="#1a0e08" stroke-width="0.7" />
            <path d="M 230 215 Q 225 222 228 230" fill="none" stroke="#1a0e08" stroke-width="0.7" />
            <!-- mustache, connecting beard -->
            <path d="M 174 196 Q 188 200 200 198 Q 212 200 226 196 Q 218 192 200 192 Q 182 192 174 196 Z" fill="#2a1810" />

            <!-- GLASSES frame -->
            <g id="glasses">
              <!-- left lens frame -->
              <rect x="148" y="160" width="42" height="34" rx="6" fill="none" stroke="#1a1a1a" stroke-width="3" />
              <!-- right lens frame -->
              <rect x="210" y="160" width="42" height="34" rx="6" fill="none" stroke="#1a1a1a" stroke-width="3" />
              <!-- bridge -->
              <line x1="190" y1="174" x2="210" y2="174" stroke="#1a1a1a" stroke-width="3" stroke-linecap="round" />
              <!-- temples -->
              <line x1="148" y1="172" x2="138" y2="174" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round" />
              <line x1="252" y1="172" x2="262" y2="174" stroke="#1a1a1a" stroke-width="2.5" stroke-linecap="round" />
              <!-- subtle lens shine -->
              <rect x="151" y="163" width="36" height="28" rx="4" fill="rgba(143,127,187,0.05)" />
              <rect x="213" y="163" width="36" height="28" rx="4" fill="rgba(143,127,187,0.05)" />
            </g>

            <!-- EYEBROWS -->
            <path id="brow-left"  d="M 152 152 Q 168 146 188 152" fill="none" stroke="#1a0e08" stroke-width="3.5" stroke-linecap="round" />
            <path id="brow-right" d="M 212 152 Q 232 146 248 152" fill="none" stroke="#1a0e08" stroke-width="3.5" stroke-linecap="round" />

            <!-- EYES — sclera (whites) -->
            <g id="eye-left">
              <ellipse cx="169" cy="178" rx="11" ry="7.5" fill="#ffffff" />
              <!-- iris + pupil group (this is what tracks mouse) -->
              <g class="eyeball">
                <circle class="iris" cx="169" cy="178" r="5.5" fill="#3d2418" />
                <circle class="pupil" cx="169" cy="178" r="3" fill="#0a0508" />
                <circle class="glint" cx="171" cy="176" r="1.4" fill="#fff" />
              </g>
              <!-- eyelid (for blink) -->
              <ellipse class="lid" cx="169" cy="178" rx="11.2" ry="0" fill="#e8b89a" />
            </g>
            <g id="eye-right">
              <ellipse cx="231" cy="178" rx="11" ry="7.5" fill="#ffffff" />
              <g class="eyeball">
                <circle class="iris" cx="231" cy="178" r="5.5" fill="#3d2418" />
                <circle class="pupil" cx="231" cy="178" r="3" fill="#0a0508" />
                <circle class="glint" cx="233" cy="176" r="1.4" fill="#fff" />
              </g>
              <ellipse class="lid" cx="231" cy="178" rx="11.2" ry="0" fill="#e8b89a" />
            </g>

            <!-- NOSE -->
            <path d="M 200 188 Q 196 205 199 215 Q 202 218 205 215 Q 204 207 200 188 Z" fill="#d4a489" />
            <ellipse cx="197" cy="216" rx="2" ry="1.5" fill="#b88a6e" />
            <ellipse cx="203" cy="216" rx="2" ry="1.5" fill="#b88a6e" />

            <!-- MOUTH (subtle smile inside beard) -->
            <path d="M 188 220 Q 200 226 212 220" fill="none" stroke="#5d3a28" stroke-width="2" stroke-linecap="round" />
          </g>
        </g>
      </svg>
    </div>

    <p class="hint">Mexa o mouse pelo viewport.</p>
  </main>

  <style>
    .avatar-stage {
      min-height: 100vh;
      display: grid;
      place-items: center;
      background:
        radial-gradient(60% 50% at 50% 35%, rgba(143,127,187,0.10) 0%, transparent 60%),
        radial-gradient(40% 40% at 80% 30%, rgba(168,198,224,0.08) 0%, transparent 60%),
        var(--color-bg, #fafaf9);
      padding: 40px 24px;
      position: relative;
    }

    .avatar-frame {
      width: min(560px, 90vw);
      aspect-ratio: 4 / 5;
      max-height: 80vh;
      margin: 0 auto;
      position: relative;
    }

    .avatar-frame svg {
      width: 100%;
      height: 100%;
      display: block;
      will-change: transform;
    }

    /* head transform driven by JS via CSS vars */
    #head {
      transform-origin: 200px 230px;
      transform: rotate(var(--head-rotate, 0deg)) translate(var(--head-x, 0), var(--head-y, 0));
      transition: transform .25s cubic-bezier(.22,.61,.36,1);
    }

    /* eyeball offset via CSS vars */
    .eyeball {
      transform-origin: center;
      transform: translate(var(--eye-x, 0), var(--eye-y, 0));
      transition: transform .12s cubic-bezier(.22,.61,.36,1);
    }

    /* breathing on torso */
    #torso {
      transform-origin: 200px 380px;
      animation: breathe 4.5s ease-in-out infinite;
    }
    @keyframes breathe {
      0%, 100% { transform: scaleY(1) translateY(0); }
      50%      { transform: scaleY(1.012) translateY(-1.5px); }
    }

    /* blink animation */
    .lid {
      animation: blink 6s ease-in-out infinite;
      transform-origin: center;
    }
    @keyframes blink {
      0%, 92%, 100% { ry: 0; }
      94%, 96% { ry: 7.5px; }
    }

    .hint {
      position: absolute;
      bottom: 32px;
      left: 0; right: 0;
      text-align: center;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 11px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--color-fg-subtle, #a8a29e);
      opacity: .8;
    }

    @media (prefers-reduced-motion: reduce) {
      #torso { animation: none; }
      .lid { animation: none; }
      #head, .eyeball { transition: none; }
    }

    @media (hover: none) {
      .hint { display: none; }
    }
  </style>

  <script is:inline>
    (() => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      const frame = document.getElementById('avatarFrame');
      const head = document.getElementById('head');
      const eyeballs = document.querySelectorAll('.eyeball');
      if (!frame || !head) return;

      let targetX = 0, targetY = 0;
      let currentX = 0, currentY = 0;

      const onMove = (e) => {
        const r = frame.getBoundingClientRect();
        // head center reference (top-ish portion of the frame)
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height * 0.32;
        const dx = (e.clientX - cx) / r.width;
        const dy = (e.clientY - cy) / r.height;
        targetX = Math.max(-1, Math.min(1, dx * 1.6));
        targetY = Math.max(-1, Math.min(1, dy * 1.6));
      };

      const onLeave = () => {
        targetX = 0;
        targetY = 0;
      };

      window.addEventListener('mousemove', onMove, { passive: true });
      window.addEventListener('mouseleave', onLeave);

      const lerp = (a, b, t) => a + (b - a) * t;

      const tick = () => {
        currentX = lerp(currentX, targetX, 0.12);
        currentY = lerp(currentY, targetY, 0.12);

        // head rotation + small translation
        const rotate = currentX * 8;        // ±8°
        const headX = currentX * 4;          // ±4px
        const headY = currentY * 3;          // ±3px

        head.style.setProperty('--head-rotate', rotate + 'deg');
        head.style.setProperty('--head-x', headX + 'px');
        head.style.setProperty('--head-y', headY + 'px');

        // eyes — finer movement than head
        const eyeX = currentX * 4;
        const eyeY = currentY * 3;
        eyeballs.forEach(el => {
          el.style.setProperty('--eye-x', eyeX + 'px');
          el.style.setProperty('--eye-y', eyeY + 'px');
        });

        requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    })();
  </script>
</BaseLayout>
