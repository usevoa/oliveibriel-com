---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";
import { cases } from "../../data/cases";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const study = cases[project.slug];

// Find adjacent project for "next" nav
const sortedFeatured = projects.filter((p) => p.featured);
const sortedRest = projects.filter((p) => !p.featured);
const ordered = [...sortedFeatured, ...sortedRest];
const idx = ordered.findIndex((p) => p.slug === project.slug);
const next = ordered[(idx + 1) % ordered.length];

// Helpers
const paragraphs = (text: string) =>
  text.split("\n\n").map((p) => p.trim()).filter(Boolean);

// Renders **bold** spans as <strong>; everything else stays plain text.
type InlineSeg = { bold: boolean; text: string };
const inlineSegments = (text: string): InlineSeg[] =>
  text
    .split(/(\*\*[^*]+\*\*)/g)
    .filter(Boolean)
    .map((part) =>
      part.startsWith("**") && part.endsWith("**")
        ? { bold: true, text: part.slice(2, -2) }
        : { bold: false, text: part },
    );
---

<BaseLayout
  title={`${project.title} — Gabriel Oliveira`}
  description={project.summary}
  type="article"
>
  <article>
    <!-- Hero -->
    <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-12 md:pt-20 pb-10 md:pb-14">
      <a
        href="/work"
        class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors mb-10"
      >
        <span class="font-mono">←</span> All work
      </a>

      <div class="grid lg:grid-cols-[1fr_18rem] gap-10 lg:gap-16 items-start">
        <div data-reveal>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-5">
            <span>{project.number}</span>
            <span>·</span>
            <span class="text-[var(--color-fg-muted)]">{project.client}</span>
            <span>·</span>
            <span>{project.year}</span>
            <span>·</span>
            <span>{project.type}</span>
            {project.ai && (
              <>
                <span>·</span>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-mono uppercase tracking-wider bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/20">AI</span>
              </>
            )}
          </div>

          <h1
            class="display text-[clamp(2.25rem,5.5vw,4.5rem)] leading-[1] mb-6"
            style="letter-spacing:-0.045em;"
          >
            {project.title}
          </h1>

          <p class="text-lg md:text-xl text-[var(--color-fg-muted)] leading-relaxed max-w-2xl">
            {study?.contextOneLiner ?? project.summary}
          </p>
        </div>

        {study && (
          <aside class="lg:sticky lg:top-24" data-reveal data-reveal-delay="2">
            <dl class="grid grid-cols-2 lg:grid-cols-1 gap-5 lg:gap-4 p-5 lg:p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
              {study.role && (
                <div>
                  <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-1">Role</dt>
                  <dd class="text-sm text-[var(--color-fg)] leading-snug">{study.role}</dd>
                </div>
              )}
              {study.team && (
                <div>
                  <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-1">Team</dt>
                  <dd class="text-sm text-[var(--color-fg)] leading-snug">{study.team}</dd>
                </div>
              )}
              {study.duration && (
                <div>
                  <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-1">Duration</dt>
                  <dd class="text-sm text-[var(--color-fg)] leading-snug">{study.duration}</dd>
                </div>
              )}
              {study.yearRange && (
                <div>
                  <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-1">Year</dt>
                  <dd class="text-sm text-[var(--color-fg)] leading-snug tabular">{study.yearRange}</dd>
                </div>
              )}
              {study.stack && study.stack.length > 0 && (
                <div class="col-span-2 lg:col-span-1">
                  <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-2">Stack</dt>
                  <dd class="flex flex-wrap gap-1.5">
                    {study.stack.map((s) => (
                      <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 rounded border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-fg-muted)]">
                        {s}
                      </span>
                    ))}
                  </dd>
                </div>
              )}
              {study.links && study.links.length > 0 && (
                <div class="col-span-2 lg:col-span-1">
                  <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-2">Links</dt>
                  <dd class="flex flex-col gap-1.5">
                    {study.links.map((link) => (
                      <a
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noopener noreferrer" : undefined}
                        class="text-sm text-[var(--color-fg)] hover:text-[var(--color-accent)] inline-flex items-center gap-1 link-underline"
                      >
                        {link.label}
                        {link.external && <span class="text-xs">↗</span>}
                      </a>
                    ))}
                  </dd>
                </div>
              )}
            </dl>
          </aside>
        )}
      </div>
    </section>

    <!-- Cover image -->
    {project.image && (
      <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pb-14 md:pb-20" data-reveal>
        <div class="aspect-[16/9] rounded-2xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
          <img
            src={project.image}
            alt={`${project.title} cover`}
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </section>
    )}

    {project.gradient && !project.image && (
      <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pb-14 md:pb-20">
        <div
          class="aspect-[16/9] rounded-2xl overflow-hidden border border-[var(--color-border)]"
          style={`background: ${project.gradient}`}
        ></div>
      </section>
    )}

    {study ? (
      <>
        <!-- Highlights row -->
        {study.highlights && study.highlights.length > 0 && (
          <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pb-12 md:pb-16" data-reveal>
            <dl class="grid grid-cols-1 sm:grid-cols-3 gap-y-8 sm:gap-x-10 max-w-4xl">
              {study.highlights.map((h, i) => (
                <div class="flex flex-col gap-1.5">
                  <dd class={`text-3xl md:text-4xl font-extrabold tabular tracking-tight leading-none ${i === 0 ? "text-[var(--color-accent)]" : ""}`}>
                    {h.value}
                  </dd>
                  <dt class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mt-1">
                    {h.label}
                  </dt>
                </div>
              ))}
            </dl>
          </section>
        )}

        <!-- Challenge -->
        <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12 md:py-16 border-t border-[var(--color-border)]">
          <div class="grid md:grid-cols-[14rem_1fr] gap-6 md:gap-12" data-reveal>
            <div>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">01</span>
              <h2 class="mt-2 text-2xl md:text-3xl font-extrabold display" style="letter-spacing:-0.035em;">
                Challenge
              </h2>
            </div>
            <div class="prose-content text-[var(--color-fg)] text-base md:text-lg leading-relaxed max-w-prose flex flex-col gap-4">
              {paragraphs(study.challenge).map((p) => (
                <p>{inlineSegments(p).map((s) => s.bold ? <strong>{s.text}</strong> : s.text)}</p>
              ))}
            </div>
          </div>
        </section>

        <!-- Approach -->
        <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12 md:py-16 border-t border-[var(--color-border)]">
          <div class="grid md:grid-cols-[14rem_1fr] gap-6 md:gap-12" data-reveal>
            <div>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">02</span>
              <h2 class="mt-2 text-2xl md:text-3xl font-extrabold display" style="letter-spacing:-0.035em;">
                Approach
              </h2>
            </div>
            <div class="prose-content text-[var(--color-fg)] text-base md:text-lg leading-relaxed max-w-prose flex flex-col gap-4">
              {paragraphs(study.approach).map((p) => (
                <p>{inlineSegments(p).map((s) => s.bold ? <strong>{s.text}</strong> : s.text)}</p>
              ))}
            </div>
          </div>
        </section>

        <!-- Outcome -->
        <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12 md:py-16 border-t border-[var(--color-border)]">
          <div class="grid md:grid-cols-[14rem_1fr] gap-6 md:gap-12" data-reveal>
            <div>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">03</span>
              <h2 class="mt-2 text-2xl md:text-3xl font-extrabold display" style="letter-spacing:-0.035em;">
                Outcome
              </h2>
            </div>
            <div class="prose-content text-[var(--color-fg)] text-base md:text-lg leading-relaxed max-w-prose flex flex-col gap-4">
              {paragraphs(study.outcome).map((p) => (
                <p>{inlineSegments(p).map((s) => s.bold ? <strong>{s.text}</strong> : s.text)}</p>
              ))}
            </div>
          </div>
        </section>

        <!-- Optional extra sections -->
        {study.sections && study.sections.length > 0 && study.sections.map((sec, i) => {
          const img = sec.image;
          const showImgPlaceholder = img && !img.src && img.placeholder;
          const aspectClass = !img
            ? ""
            : img.aspect === "tall"
            ? "aspect-[3/4]"
            : img.aspect === "square"
            ? "aspect-square"
            : "aspect-[16/9]";
          const defaultGradient =
            "linear-gradient(135deg, #1e293b 0%, #1e3a8a 55%, #1d4ed8 100%)";
          return (
            <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12 md:py-16 border-t border-[var(--color-border)]">
              <div class="grid md:grid-cols-[14rem_1fr] gap-6 md:gap-12" data-reveal>
                <div>
                  <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">{String(i + 4).padStart(2, "0")}</span>
                  <h2 class="mt-2 text-2xl md:text-3xl font-extrabold display" style="letter-spacing:-0.035em;">
                    {sec.heading}
                  </h2>
                </div>
                <div class="flex flex-col gap-8">
                  <div class="prose-content text-[var(--color-fg)] text-base md:text-lg leading-relaxed max-w-prose flex flex-col gap-4">
                    {paragraphs(sec.body).map((p) => (
                      <p>{inlineSegments(p).map((s) => s.bold ? <strong>{s.text}</strong> : s.text)}</p>
                    ))}
                  </div>

                  {img && (
                    <figure class="mt-2">
                      <div
                        class={`relative overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] ${aspectClass}`}
                        style={showImgPlaceholder ? `background: ${img.placeholder!.gradient || defaultGradient};` : undefined}
                      >
                        {img.src && (
                          <img
                            src={img.src}
                            alt={img.alt}
                            class="w-full h-full object-cover"
                            loading="lazy"
                          />
                        )}
                        {showImgPlaceholder && (
                          <div class="absolute inset-0 flex flex-col items-start justify-end p-6 md:p-8 gap-3 text-white">
                            <span class="font-mono text-[10px] uppercase tracking-[0.16em] opacity-75 inline-flex items-center gap-2">
                              <span class="size-1.5 rounded-full bg-[var(--color-accent-tint)] animate-pulse"></span>
                              Placeholder · capture pending
                            </span>
                            <span class="text-2xl md:text-3xl font-extrabold tracking-tight leading-tight" style="letter-spacing:-0.025em;">
                              {img.placeholder!.label}
                            </span>
                            {img.placeholder!.sublabel && (
                              <span class="font-mono text-[11px] uppercase tracking-wider opacity-80">
                                {img.placeholder!.sublabel}
                              </span>
                            )}
                          </div>
                        )}
                      </div>
                      {img.caption && (
                        <figcaption class="mt-3 font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
                          {img.caption}
                        </figcaption>
                      )}
                    </figure>
                  )}
                </div>
              </div>
            </section>
          );
        })}

        <!-- Gallery -->
        {study.gallery && study.gallery.length > 0 && (
          <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12 md:py-16 border-t border-[var(--color-border)]">
            <div class="flex items-baseline justify-between mb-8">
              <h2 class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Selected screens</h2>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">{study.gallery.length} captures</span>
            </div>
            <div class="grid md:grid-cols-2 gap-6 md:gap-8">
              {study.gallery.map((img) => {
                const aspectClass =
                  img.aspect === "tall"
                    ? "aspect-[3/4]"
                    : img.aspect === "square"
                    ? "aspect-square"
                    : "aspect-[16/9]";
                const wide = img.aspect === "wide";
                const showPlaceholder = !img.src && img.placeholder;
                const defaultGradient =
                  "linear-gradient(135deg, #1e293b 0%, #1e3a8a 55%, #1d4ed8 100%)";
                return (
                  <figure class={wide ? "md:col-span-2" : ""}>
                    <div
                      class={`relative overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] ${aspectClass}`}
                      style={showPlaceholder ? `background: ${img.placeholder!.gradient || defaultGradient};` : undefined}
                    >
                      {img.src && (
                        <img
                          src={img.src}
                          alt={img.alt}
                          class="w-full h-full object-cover"
                          loading="lazy"
                        />
                      )}
                      {showPlaceholder && (
                        <div class="absolute inset-0 flex flex-col items-start justify-end p-6 md:p-8 gap-3 text-white">
                          <span class="font-mono text-[10px] uppercase tracking-[0.16em] opacity-75 inline-flex items-center gap-2">
                            <span class="size-1.5 rounded-full bg-[var(--color-accent-tint)] animate-pulse"></span>
                            Placeholder · capture pending
                          </span>
                          <span class="text-2xl md:text-3xl font-extrabold tracking-tight leading-tight" style="letter-spacing:-0.025em;">
                            {img.placeholder!.label}
                          </span>
                          {img.placeholder!.sublabel && (
                            <span class="font-mono text-[11px] uppercase tracking-wider opacity-80">
                              {img.placeholder!.sublabel}
                            </span>
                          )}
                          <div class="absolute top-6 right-6 md:top-8 md:right-8 flex items-center gap-1.5">
                            {[0, 1, 2].map(() => (
                              <span class="size-1 rounded-full bg-white/40"></span>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                    {img.caption && (
                      <figcaption class="mt-3 font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
                        {img.caption}
                      </figcaption>
                    )}
                  </figure>
                );
              })}
            </div>
          </section>
        )}

        <!-- Reflection (pull quote style) -->
        {study.reflection && (
          <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 md:py-20 border-t border-[var(--color-border)]">
            <div class="max-w-3xl" data-reveal>
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Reflection</span>
              <blockquote class="mt-4 text-2xl md:text-3xl font-medium leading-snug tracking-tight text-[var(--color-fg)]" style="letter-spacing:-0.025em;">
                <span class="text-[var(--color-fg-faint)] font-serif">"</span>
                {study.reflection}
                <span class="text-[var(--color-fg-faint)] font-serif">"</span>
              </blockquote>
            </div>
          </section>
        )}
      </>
    ) : (
      <section class="max-w-[var(--container-prose)] mx-auto px-6 md:px-10 py-16 border-t border-[var(--color-border)]">
        <p class="font-mono text-sm text-[var(--color-fg-subtle)]">
          Full case study being migrated. Reach out if you'd like to see the work in detail.
        </p>
      </section>
    )}

    <!-- Next project -->
    {next && (
      <section class="border-t border-[var(--color-border)] mt-8">
        <a
          href={`/work/${next.slug}`}
          class="block max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-16 md:py-24 group"
        >
          <div class="flex items-baseline justify-between gap-6 mb-4">
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Next project</span>
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">{next.number} · {next.year}</span>
          </div>
          <div class="flex items-center justify-between gap-6">
            <h3 class="text-3xl md:text-5xl lg:text-6xl font-extrabold display group-hover:text-[var(--color-accent)] transition-colors" style="letter-spacing:-0.045em;">
              {next.title}
            </h3>
            <span class="text-3xl md:text-5xl text-[var(--color-fg-faint)] group-hover:text-[var(--color-accent)] group-hover:translate-x-2 transition-all">→</span>
          </div>
          <p class="mt-3 text-[var(--color-fg-muted)] max-w-2xl">{next.summary}</p>
        </a>
      </section>
    )}
  </article>
</BaseLayout>
