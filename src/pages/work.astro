---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featured, archive } from "../data/projects";
---

<BaseLayout
  title="Work — Gabriel Oliveira"
  description="Selected case studies in industrial SaaS, design systems, and AI-native product design."
>
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-12">
    <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
      Work
    </span>
    <h1
      class="mt-3 text-4xl md:text-6xl font-extrabold"
      style="letter-spacing: -0.045em;"
    >
      Selected case studies.
    </h1>
    <p class="mt-5 text-lg text-[var(--color-fg-muted)] max-w-2xl leading-relaxed">
      A curated set of projects in B2B SaaS, design systems, and AI-native tools.
      Each one documents process, decisions, and trade-offs.
    </p>
  </section>

  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
        Featured
      </h2>
      <span class="font-mono text-xs text-[var(--color-fg-subtle)]">{featured.length} projects</span>
    </div>
    <div class="grid md:grid-cols-2 gap-5">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12 border-t border-[var(--color-border)]">
    <div class="flex items-baseline justify-between mb-8">
      <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
        Archive
      </h2>
      <span class="font-mono text-xs text-[var(--color-fg-subtle)]">{archive.length} projects</span>
    </div>
    <ul class="divide-y divide-[var(--color-border)]">
      {archive.map((project) => (
        <li>
          <a
            href={`/work/${project.slug}`}
            class="grid grid-cols-[3rem_1fr_auto] md:grid-cols-[3rem_1fr_1fr_auto] items-center gap-4 py-4 hover:bg-[var(--color-bg-elevated)] -mx-4 px-4 rounded-lg transition-colors"
          >
            <span class="font-mono text-xs text-[var(--color-fg-subtle)]">{project.number}</span>
            <span class="font-medium">{project.title}</span>
            <span class="hidden md:block font-mono text-xs text-[var(--color-fg-subtle)]">{project.type}</span>
            <span class="font-mono text-xs text-[var(--color-fg-subtle)]">{project.year}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
