---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";

// Featured cases as editorial rows, curated order (strongest first).
const FEATURED_ORDER = [
  "iris-v3",
  "norius",
  "nerida",
  "netzsch-design-system",
  "techcolab",
  "myct-connecticut",
];
const featuredRows = FEATURED_ORDER
  .map((slug) => projects.find((p) => p.slug === slug))
  .filter(Boolean);

// Full index — chronological accession, newest first.
const sortedAll = [...projects].sort(
  (a, b) => parseInt(b.number) - parseInt(a.number)
);
const yearSpan = `${Math.min(...projects.map((p) => parseInt(p.year)))} → ${Math.max(...projects.map((p) => parseInt(p.year)))}`;
---

<BaseLayout
  title="Work — Gabriel Oliveira"
  description="Case studies across industrial SaaS, design systems, AI-native tools, fintech, and public-sector platforms."
>
  <!-- Page hero -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-14 md:pt-20 pb-12">
    <span class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
      Work · {projects.length} projects · {yearSpan}
    </span>
    <h1
      class="mt-3 text-4xl md:text-6xl font-extrabold display"
      style="letter-spacing:-0.045em;"
    >
      Everything I've shipped<br />in the last decade.
    </h1>
    <p class="mt-5 text-lg text-[var(--color-fg-muted)] max-w-2xl leading-relaxed">
      Industrial SaaS, design systems, AI-native tools, fintech, public-sector
      platforms, and a couple of indie games to prove I started somewhere weird.
    </p>
  </section>

  <!-- Featured cases — editorial rows -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pb-20">
    <h2 class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)] mb-8">
      Featured cases
    </h2>
    <div class="flex flex-col gap-14 md:gap-20">
      {featuredRows.map((project, i) => (
        <a
          href={`/work/${project.slug}`}
          class="feature-row group grid md:grid-cols-12 gap-6 md:gap-10 items-center"
          data-reveal
        >
          <div class={`md:col-span-7 ${i % 2 === 1 ? "md:order-2" : ""}`}>
            <div class="feature-row__media aspect-[16/10] overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
              {project.image ? (
                <img
                  src={project.image}
                  alt={`${project.title} cover`}
                  loading={i < 2 ? "eager" : "lazy"}
                  decoding="async"
                  class="feature-row__img w-full h-full object-cover"
                />
              ) : (
                <div
                  class="w-full h-full"
                  style={`background:${project.gradient ?? "linear-gradient(135deg,#1f2937,#111827)"}`}
                />
              )}
            </div>
          </div>
          <div class={`md:col-span-5 ${i % 2 === 1 ? "md:order-1" : ""}`}>
            <div class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
              <span>{project.number} · {project.client}</span>
              {project.ai && (
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/20">
                  AI
                </span>
              )}
            </div>
            <h3
              class="mt-2.5 text-2xl md:text-[2rem] font-bold leading-tight group-hover:text-[var(--color-accent)] transition-colors"
              style="letter-spacing:-0.03em;"
            >
              {project.title}
            </h3>
            <p class="mt-3 text-[15px] text-[var(--color-fg-muted)] leading-relaxed max-w-prose">
              {project.summary}
            </p>
            <div class="mt-4 flex items-center gap-3 font-mono text-[11px] text-[var(--color-fg-subtle)]">
              {project.metric && (
                <>
                  <span>
                    <span class="text-[var(--color-fg)] font-semibold tabular">{project.metric.value}</span>
                    {" "}{project.metric.label.toLowerCase()}
                  </span>
                  <span class="opacity-50">·</span>
                </>
              )}
              <span>{project.year}</span>
              <span
                class="ml-auto inline-flex items-center gap-1 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-[var(--color-accent)]"
                aria-hidden="true"
              >
                Read →
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Index table — every project -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-14 border-t border-[var(--color-border)]">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
        Full index
      </h2>
      <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
        {sortedAll.length} projects
      </span>
    </div>

    <div class="hidden md:grid grid-cols-[3rem_2.4fr_1.6fr_1.4fr_5rem_1.5rem] gap-4 px-3 pb-2 mb-1 border-b border-[var(--color-border)] font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
      <span>#</span><span>Project</span><span>Client</span><span>Type</span><span>Year</span><span></span>
    </div>

    <ul class="divide-y divide-[var(--color-border)]">
      {sortedAll.map((project) => (
        <li>
          <a
            href={`/work/${project.slug}`}
            class="grid md:grid-cols-[3rem_2.4fr_1.6fr_1.4fr_5rem_1.5rem] grid-cols-[2.4rem_1fr_auto] items-center gap-3 md:gap-4 py-3.5 px-3 -mx-3 rounded-lg hover:bg-[var(--color-bg-elevated)] transition-colors group"
          >
            <span class="font-mono text-[11px] text-[var(--color-fg-subtle)]">{project.number}</span>
            <span class="font-medium text-[var(--color-fg)] flex items-center gap-2">
              {project.title}
              {project.ai && (
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-mono uppercase tracking-wider bg-[var(--color-accent)]/10 text-[var(--color-accent)] border border-[var(--color-accent)]/20">
                  AI
                </span>
              )}
              {project.featured && (
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-mono uppercase tracking-wider text-[var(--color-fg-subtle)] border border-[var(--color-border)]">
                  Featured
                </span>
              )}
            </span>
            <span class="hidden md:block font-mono text-xs text-[var(--color-fg-muted)]">{project.client}</span>
            <span class="hidden md:block font-mono text-xs text-[var(--color-fg-subtle)]">{project.type}</span>
            <span class="hidden md:block font-mono text-xs text-[var(--color-fg-subtle)] tabular">{project.year}</span>
            <span class="font-mono text-xs text-[var(--color-fg-subtle)] opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- CTA -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20 border-t border-[var(--color-border)]">
    <div class="flex flex-col gap-5 max-w-2xl">
      <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
        Working on something hard?
      </span>
      <h2 class="text-3xl md:text-5xl font-extrabold display" style="letter-spacing:-0.045em;">
        Let's get into the weeds together.
      </h2>
      <a
        href="mailto:gabriel@oliveibriel.com"
        class="self-start inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[var(--color-fg)] hover:bg-[var(--color-accent)] text-white text-sm font-medium transition-colors mt-2"
      >
        gabriel@oliveibriel.com
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 17 7M7 7h10v10"/>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .feature-row__img {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .feature-row:hover .feature-row__img {
    transform: scale(1.02);
  }
</style>
