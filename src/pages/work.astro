---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Work — Gabriel Oliveira"
  description="Selected case studies in industrial SaaS, design systems, and AI-native product design."
>
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-20 pb-12">
    <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
      Work
    </span>
    <h1
      class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight"
      style="letter-spacing: var(--tracking-tightest);"
    >
      Selected case studies.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-fg-muted)] max-w-2xl">
      A curated set of projects in B2B SaaS, design systems, and AI-native
      tools. Each one documents the process, decisions, and trade-offs.
    </p>
  </section>

  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-12">
    <p class="font-mono text-sm text-[var(--color-fg-subtle)]">
      Case studies are being migrated. Check back soon.
    </p>
  </section>
</BaseLayout>
