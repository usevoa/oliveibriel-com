---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ContactForm from "../components/ContactForm.astro";
import { featured, personal } from "../data/projects";

const clients = [
  "NETZSCH",
  "Connecticut.gov",
  "Dell",
  "Santander",
  "TechCo.lab",
  "Rotary",
  "VOA Digital",
];

const fullName = "Gabriel Oliveira";
const words = fullName.split(" ").map((w) => Array.from(w));
let charIndex = 0;
---

<BaseLayout>
  <!-- Hero — recruiter-friendly, compact, motion-rich -->
  <section class="relative">
    <div class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-12 md:pt-20 pb-16 md:pb-24">
      <!-- Hero — single column, text-led (video bg incoming) -->
      <div class="flex flex-col gap-7 md:gap-9 max-w-[60ch]">
        <h1
          class="display text-[clamp(2.75rem,7.4vw,6rem)] leading-[0.95]"
          aria-label={fullName}
        >
          <span class="hero-name" aria-hidden="true">
            {words.map((wordChars, wIdx) => (
              <>
                <span class="word">
                  {wordChars.map((c) => {
                    const i = charIndex++;
                    return <span class="ch" data-i={i}>{c}</span>;
                  })}
                </span>{wIdx < words.length - 1 ? "\u00A0" : ""}
              </>
            ))}
          </span>
        </h1>

        <p class="text-xl md:text-2xl text-[var(--color-fg-muted)] leading-snug" data-reveal data-reveal-delay="3">
          I design and ship
          <span class="kw">industrial SaaS</span>,
          <span class="kw">design systems</span>, and
          <span class="kw">AI-native tools</span>.
          Currently leading UX on
          <span class="font-medium text-[var(--color-fg)]">IRIS V3</span> at
          <span class="font-medium text-[var(--color-fg)]">NETZSCH</span>
          and co-running
          <span class="font-medium text-[var(--color-fg)]">VOA Digital</span>.
        </p>

        <div class="flex flex-wrap items-center gap-3 mt-2" data-reveal data-reveal-delay="4">
          <a
            href="/work"
            class="magnetic group inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[var(--color-fg)] hover:bg-[var(--color-accent)] text-white text-sm font-medium transition-colors"
            data-magnetic-strength="10"
          >
            View selected work
            <svg class="size-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="mailto:gabriel@oliveibriel.com"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-md border border-[var(--color-border-strong)] hover:border-[var(--color-fg)] hover:bg-[var(--color-bg-soft)] text-[var(--color-fg)] text-sm font-medium transition-colors"
          >
            Get in touch
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Receipts — three big numbers, attributed -->
        <dl class="mt-10 md:mt-14 grid grid-cols-1 sm:grid-cols-3 gap-y-8 sm:gap-x-10 max-w-3xl" data-reveal data-reveal-delay="5">
          <div class="flex flex-col gap-2 group">
            <dd class="text-4xl md:text-5xl font-extrabold tabular tracking-tight leading-none text-[var(--color-accent)]">
              −40<span class="text-3xl md:text-4xl">%</span>
            </dd>
            <dt class="text-sm md:text-base text-[var(--color-fg-muted)] leading-snug">
              faster operator onboarding on <span class="font-medium text-[var(--color-fg)]">IRIS V3</span>
            </dt>
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">NETZSCH · 2024</span>
          </div>
          <div class="flex flex-col gap-2 group">
            <dd class="text-4xl md:text-5xl font-extrabold tabular tracking-tight leading-none">
              3M<span class="text-[var(--color-fg-subtle)] text-3xl md:text-4xl">+</span>
            </dd>
            <dt class="text-sm md:text-base text-[var(--color-fg-muted)] leading-snug">
              users reached across <span class="font-medium text-[var(--color-fg)]">SuperDigital</span> LATAM
            </dt>
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Santander · 2019</span>
          </div>
          <div class="flex flex-col gap-2 group">
            <dd class="text-4xl md:text-5xl font-extrabold tabular tracking-tight leading-none">
              8<span class="text-[var(--color-fg-subtle)] text-3xl md:text-4xl"> teams</span>
            </dd>
            <dt class="text-sm md:text-base text-[var(--color-fg-muted)] leading-snug">
              shipping on the <span class="font-medium text-[var(--color-fg)]">NETZSCH DS</span> I built
            </dt>
            <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">NETZSCH · 2023→</span>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- Trusted by — readable, framed -->
  <section class="border-y border-[var(--color-border)] py-7 overflow-hidden bg-[var(--color-bg-soft)]">
    <div class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10">
      <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--color-fg-subtle)] mb-4">
        Trusted by · Selected clients
      </div>
      <div class="flex marquee whitespace-nowrap gap-x-14 font-mono text-sm uppercase tracking-[0.16em] text-[var(--color-fg)] font-medium">
        {[...Array(3)].flatMap(() =>
          clients.map((c) => (
            <span class="inline-flex items-center gap-x-14">
              {c}
              <span class="size-1.5 rounded-full bg-[var(--color-accent)]"></span>
            </span>
          ))
        )}
      </div>
    </div>
  </section>

  <!-- Selected work — clean 2-col grid -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20 md:py-28">
    <div class="flex items-end justify-between mb-12" data-reveal>
      <div>
        <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Selected work</span>
        <h2 class="mt-2 text-3xl md:text-5xl font-extrabold display">
          Recent projects.
        </h2>
      </div>
      <a
        href="/work"
        class="link-underline text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"
      >
        All 14 projects →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {featured.map((project, i) => <ProjectCard project={project} index={i} size="normal" />)}
    </div>
  </section>

  {personal.length > 0 && (
    <!-- Personal projects — side bets, OSS, vibe-coded experiments -->
    <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pb-20 md:pb-28">
      <div class="flex items-end justify-between mb-10 gap-6 flex-wrap" data-reveal>
        <div>
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Personal projects</span>
          <h2 class="mt-2 text-3xl md:text-5xl font-extrabold display">
            Side bets &amp; weekend builds.
          </h2>
        </div>
        <p class="text-[var(--color-fg-muted)] leading-relaxed text-sm md:text-base max-w-md">
          Things I built for myself — open source, AI-native, shipped because I wanted them to exist.
        </p>
      </div>
      <div class={`grid gap-6 md:gap-8 ${personal.length === 1 ? "grid-cols-1 max-w-3xl" : "grid-cols-1 md:grid-cols-2"}`}>
        {personal.map((project, i) => <ProjectCard project={project} index={i} size={personal.length === 1 ? "wide" : "normal"} />)}
      </div>
    </section>
  )}

  <!-- How I work — 4 horizontal cards -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20 md:py-28 border-t border-[var(--color-border)]">
    <div class="flex items-end justify-between mb-10 md:mb-14 gap-6 flex-wrap" data-reveal>
      <div>
        <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Approach</span>
        <h2 class="mt-2 text-3xl md:text-5xl font-extrabold display">
          How I work.
        </h2>
      </div>
      <p class="text-[var(--color-fg-muted)] leading-relaxed text-sm md:text-base max-w-md">
        Less manifesto, more receipts. Each principle maps to something I've actually shipped.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        {
          n: "01",
          t: "Ship before you generalize",
          d: "Build the messy v1 with real users, then extract patterns. IRIS V3's DS started as five operator screens — not a token table.",
          tag: "IRIS V3",
        },
        {
          n: "02",
          t: "Design for the operator",
          d: "Industrial software lives under PPE and time pressure. Color, hierarchy, and feedback are tuned for worst lighting — not the marketing shot.",
          tag: "NETZSCH HMIs",
        },
        {
          n: "03",
          t: "Own the full stack",
          d: "I move from Figma to React to deploy when it's faster. Nerida and the VOA Portal shipped solo, end-to-end, with Claude Code as build partner.",
          tag: "Nerida · VOA Portal",
        },
        {
          n: "04",
          t: "AI for the boring parts",
          d: "LLMs handle scaffolding, schema mapping, copy drafts, and scripts. Taste, decisions, and the system itself stay mine.",
          tag: "Garmin Coach",
        },
      ].map((step, i) => (
        <article
          class="howiwork-card group bg-[var(--color-bg-elevated)] border border-[var(--color-border)] rounded-xl p-6 flex flex-col gap-4 transition-all"
          data-reveal
          data-reveal-delay={i + 1}
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">{step.n}</span>
            <span class="size-1.5 rounded-full bg-[var(--color-border-strong)] group-hover:bg-[var(--color-accent)] transition-colors"></span>
          </div>
          <h3 class="text-lg md:text-xl font-bold tracking-tight leading-snug" style="letter-spacing:-0.025em;">
            {step.t}
          </h3>
          <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed flex-1">
            {step.d}
          </p>
          <div class="pt-3 border-t border-[var(--color-border)] inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-wider text-[var(--color-accent)]">
            <span class="size-1 rounded-full bg-[var(--color-accent)]"></span>
            {step.tag}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Get in touch — form -->
  <section id="contact" class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20 md:py-28 border-t border-[var(--color-border)]">
    <div class="grid lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-20">
      <div class="flex flex-col items-start gap-6" data-reveal>
        <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-fg-subtle)]">Get in touch</span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold display">
          Got a hard product problem?
          <span class="block text-[var(--color-fg-muted)] display-italic mt-2">Let's solve it.</span>
        </h2>
        <p class="text-base md:text-lg text-[var(--color-fg-muted)] max-w-md">
          Currently open to product design and AI-native build engagements. I respond within a few days.
        </p>
        <ul class="mt-2 flex flex-col gap-3 font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-muted)]">
          <li class="flex items-center gap-3">
            <span class="size-1.5 rounded-full bg-[var(--color-accent)]"></span>
            Product design · AI-native builds
          </li>
          <li class="flex items-center gap-3">
            <span class="size-1.5 rounded-full bg-[var(--color-accent)]"></span>
            Remote · UTC−3 · EN / PT-BR
          </li>
          <li class="flex items-center gap-3">
            <span class="size-1.5 rounded-full bg-[var(--color-accent)]"></span>
            Available May 2026
          </li>
        </ul>
      </div>

      <ContactForm />
    </div>
  </section>
</BaseLayout>
