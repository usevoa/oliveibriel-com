---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { featured } from "../data/projects";
---

<BaseLayout>
  <!-- Hero -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 pt-16 md:pt-24 pb-16">
    <div class="grid md:grid-cols-[1fr_auto] gap-10 md:gap-16 items-start">
      <div class="flex flex-col gap-7 max-w-3xl">
        <span
          class="inline-flex items-center gap-2 self-start px-3 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-accent-bg)] text-[var(--color-accent-soft)] text-xs font-medium"
        >
          <span class="size-1.5 rounded-full bg-[var(--color-success)] animate-pulse"></span>
          Available for new projects
        </span>

        <h1
          class="text-[2.75rem] md:text-6xl lg:text-[5rem] font-extrabold leading-[0.98]"
          style="letter-spacing: -0.045em;"
        >
          Senior Product Designer.
          <span class="block text-[var(--color-fg-muted)] font-light italic" style="letter-spacing: -0.04em;">
            Industrial SaaS, design systems, AI-native tools.
          </span>
        </h1>

        <p class="text-base md:text-lg text-[var(--color-fg-muted)] max-w-xl leading-relaxed">
          I work on <span class="text-[var(--color-fg)]">IRIS V3</span> at NETZSCH and
          run <span class="text-[var(--color-fg)]">VOA Digital</span> with my sister.
          Currently building products where design and AI ship together.
        </p>

        <div class="flex flex-wrap items-center gap-3 pt-1">
          <a
            href="/work"
            class="group inline-flex items-center gap-2 px-4 py-2.5 rounded-md bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-sm font-medium transition-colors"
          >
            View selected work
            <svg class="size-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="/about"
            class="inline-flex items-center gap-2 px-4 py-2.5 rounded-md border border-[var(--color-border)] hover:bg-[var(--color-bg-elevated)] text-sm font-medium transition-colors"
          >
            About me
          </a>
        </div>

        <dl class="mt-6 grid grid-cols-3 gap-4 max-w-md font-mono text-[11px] uppercase tracking-wider text-[var(--color-fg-subtle)]">
          <div class="flex flex-col gap-1">
            <dt>Based in</dt>
            <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">Curitiba, BR</dd>
          </div>
          <div class="flex flex-col gap-1">
            <dt>Currently</dt>
            <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">NETZSCH · VOA</dd>
          </div>
          <div class="flex flex-col gap-1">
            <dt>Years</dt>
            <dd class="text-[var(--color-fg)] normal-case tracking-normal text-sm font-sans">10+</dd>
          </div>
        </dl>
      </div>

      <div class="hidden md:block w-[280px] lg:w-[320px] aspect-[4/5] rounded-xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
        <img
          src="https://storage.googleapis.com/2026portfolio/Home/Link.jpg"
          alt="Gabriel Oliveira"
          class="w-full h-full object-cover [filter:grayscale(15%)] hover:[filter:grayscale(0)] transition-all duration-700 hover:scale-[1.02]"
        />
      </div>
    </div>
  </section>

  <!-- Selected work -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20">
    <div class="flex items-baseline justify-between mb-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Selected work</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          Recent projects.
        </h2>
      </div>
      <a
        href="/work"
        class="link-underline text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"
      >
        All projects →
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {featured.slice(0, 6).map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <!-- Approach -->
  <section class="max-w-[var(--container-wide)] mx-auto px-6 md:px-10 py-20 border-t border-[var(--color-border)]">
    <div class="grid md:grid-cols-[280px_1fr] gap-10">
      <div>
        <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">Approach</span>
        <h2 class="mt-2 text-2xl md:text-3xl font-bold tracking-tight" style="letter-spacing: -0.03em;">
          How I work.
        </h2>
      </div>
      <ol class="grid gap-6">
        <li class="flex gap-4">
          <span class="font-mono text-xs text-[var(--color-fg-subtle)] mt-1 w-8 shrink-0">01</span>
          <div>
            <h3 class="text-base font-semibold mb-1">Evidence-based design</h3>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
              Research, testing, and workshops drive what we build — not opinions.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="font-mono text-xs text-[var(--color-fg-subtle)] mt-1 w-8 shrink-0">02</span>
          <div>
            <h3 class="text-base font-semibold mb-1">Systems thinking</h3>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
              Flows, IA, and reusable components — never just isolated screens.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="font-mono text-xs text-[var(--color-fg-subtle)] mt-1 w-8 shrink-0">03</span>
          <div>
            <h3 class="text-base font-semibold mb-1">Cross-functional craft</h3>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
              Aligning with PMs and engineers from kickoff through ship.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="font-mono text-xs text-[var(--color-fg-subtle)] mt-1 w-8 shrink-0">04</span>
          <div>
            <h3 class="text-base font-semibold mb-1">AI as a build partner</h3>
            <p class="text-sm text-[var(--color-fg-muted)] leading-relaxed">
              Prototyping, scripting, scaffolding — using LLMs to ship faster without giving up taste.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>
</BaseLayout>
