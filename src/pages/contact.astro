---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — Gabriel Oliveira"
  description="Get in touch about new projects or collaborations."
>
  <section class="max-w-[var(--container-prose)] mx-auto px-6 md:px-10 pt-20 pb-20">
    <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
      Contact
    </span>
    <h1
      class="mt-3 text-4xl md:text-5xl font-extrabold tracking-tight"
      style="letter-spacing: var(--tracking-tightest);"
    >
      Let's talk.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-fg-muted)] max-w-xl">
      I'm currently open to new freelance and full-time opportunities. Send a
      note and I'll get back to you within a few days.
    </p>

    <div class="mt-10 flex flex-col gap-3">
      <a
        href="mailto:oliveibriel@gmail.com"
        class="inline-flex items-center justify-between gap-4 px-5 py-4 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-elevated)] transition-colors"
      >
        <div class="flex flex-col">
          <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
            Email
          </span>
          <span class="text-base mt-1">oliveibriel@gmail.com</span>
        </div>
        <span class="text-[var(--color-accent-soft)]">→</span>
      </a>

      <a
        href="https://www.linkedin.com/in/oliveibriel"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-between gap-4 px-5 py-4 rounded-lg border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-elevated)] transition-colors"
      >
        <div class="flex flex-col">
          <span class="font-mono text-xs uppercase tracking-wider text-[var(--color-fg-subtle)]">
            LinkedIn
          </span>
          <span class="text-base mt-1">/in/oliveibriel</span>
        </div>
        <span class="text-[var(--color-accent-soft)]">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
